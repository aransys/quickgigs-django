# =========================================================================
# QuickGigs environment configuration
# Copy to .env and fill in real values. NEVER commit .env to git.
# =========================================================================

# Which settings module to load. Options:
#   config.settings.dev   - local development (default)
#   config.settings.prod  - production (Docker / generic deploy)
#   config.settings.test  - test runner
DJANGO_SETTINGS_MODULE=config.settings.dev

# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me

# True/False - never True in production
DJANGO_DEBUG=True

# Comma-separated list of allowed hostnames
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of trusted origins for CSRF (only needed in prod)
# DJANGO_CSRF_TRUSTED_ORIGINS=https://quickgigs.example.com

# Database URL. Examples:
#   sqlite:///db.sqlite3
#   postgres://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Stripe — leave empty to disable payments locally
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FEATURED_GIG_PRICE=9.99
